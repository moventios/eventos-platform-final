# Salin ke .env (root) dan apps/web/.env.local, lalu sesuaikan jika perlu.
#
# Setup lokal:
#   1. cp .env.example .env
#   2. cp .env.example apps/web/.env.local  (hanya baris Supabase + App + TENANT_COOKIE_SECRET)
#   3. Jalankan Docker Desktop
#   4. supabase start
#   5. pnpm --filter @eventos/database db:push
#   6. pnpm dev
#
# Kunci di bawah adalah default Supabase local (supabase start).
# Setelah start, Anda bisa memverifikasi dengan: supabase status

# Supabase API
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQv-8Hiz3A4o3MjQyTmEU

# PostgreSQL (port dari supabase/config.toml → [db] port = 54322)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# URL app untuk SSR internal fetch (wajib di production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# HMAC secret untuk signed tenant cookie (generate: openssl rand -hex 32)
# Di production wajib di-set; di local bisa pakai nilai acak tetap.
TENANT_COOKIE_SECRET=

# Trigger.dev (opsional — apps/workers)
TRIGGER_SECRET_KEY=

# CI / deploy
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_ID=